DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_SSL=require

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_STORAGE_BUCKET=mosaico

ADMIN_EMAILS=admin@example.com
CORS_ORIGINS=http://localhost:3000,https://your-frontend.onrender.com
LOCAL_AUTH_SESSION_MINUTES=10080

STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional per-teacher Google Calendar integration. Keep disabled until Google
# Cloud, migration, cron, and pilot validation are complete.
GOOGLE_CALENDAR_INTEGRATION_ENABLED=false
GOOGLE_CALENDAR_CLIENT_ID=your-google-web-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=your-google-web-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=https://your-backend.example/api/integrations/google-calendar/callback
GOOGLE_CALENDAR_FRONTEND_RETURN_URL=https://your-frontend.example/teacher/calendar
GOOGLE_CALENDAR_ENCRYPTION_KEY=generate-a-valid-fernet-key
GOOGLE_CALENDAR_STATE_SECRET=generate-an-independent-high-entropy-secret
GOOGLE_CALENDAR_SYNC_WINDOW_DAYS=60
GOOGLE_CALENDAR_CACHE_TTL_SECONDS=300
GOOGLE_CALENDAR_REQUEST_TIMEOUT_SECONDS=12
GOOGLE_CALENDAR_MAX_RETRIES=3
